-- ====================== BRAINROT HUB (AUTO DROP VIA REMOTE + AUTO COLLECT) ======================
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- ПОИСК РЕМУТА ДЛЯ ДРОПА
local dropRemote = nil
local remotes = ReplicatedStorage:FindFirstChild("RemoteEvents")
if remotes then
    for _, child in ipairs(remotes:GetChildren()) do
        if child.Name:find("Drop") or child.Name:find("Ball") then
            dropRemote = child
            print("🔍 Найден ремут для дропа:", child.Name)
        end
    end
end

-- Если не нашли ремут, используем эмуляцию кнопки (запасной вариант)
local function dropBallViaRemote()
    if dropRemote then
        pcall(function()
            dropRemote:FireServer()
        end)
        return true
    end
    return false
end

-- ЭМУЛЯЦИЯ ТАПА (запасной вариант)
local vim = game:GetService("VirtualInputManager")
local function tap(x, y)
    pcall(function()
        vim:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait(0.02)
        vim:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end)
end

-- ПОИСК КНОПКИ ПО ИМЕНИ
local function findButton(buttonName)
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return nil, 0, 0 end
    
    local function search(container)
        for _, child in ipairs(container:GetChildren()) do
            if (child:IsA("TextButton") or child:IsA("ImageButton")) and child.Name == buttonName then
                local pos = child.AbsolutePosition
                local size = child.AbsoluteSize
                if pos.X > 0 and pos.Y > 0 then
                    return child, pos.X + size.X/2, pos.Y + size.Y/2
                end
            end
            local found, x, y = search(child)
            if found then return found, x, y end
        end
        return nil, 0, 0
    end
    
    return search(playerGui)
end

-- НАЖАТИЕ НА КНОПКУ
local function clickButton(buttonName)
    local btn, x, y = findButton(buttonName)
    if btn and x > 0 and y > 0 then
        tap(x, y)
        return true
    end
    return false
end

