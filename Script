    autoCollect = not autoCollect
    if autoCollect then
        btnCollect.Text = "🟢 AUTO COLLECT: ON"
        btnCollect.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
    else
        btnCollect.Text = "🔴 AUTO COLLECT: OFF"
        btnCollect.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    end
end)

btnDiag.MouseButton1Click:Connect(function()
    findDropButtons()
end)

closeBtn.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)

-- СБОРКА GUI
for _, obj in ipairs({mainFrame, title, closeBtn, btnDrop, btnCollect, btnDiag}) do
    obj.Parent = screenGui
end
mainFrame.Parent = screenGui
screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

-- ====================== ОСНОВНЫЕ ЦИКЛЫ ======================

-- АВТО-ДРОП (по 1 шару)
task.spawn(function()
    while true do
        task.wait(dropDelay)
        if autoDrop then
            -- Ищем кнопку DropButton или любую кнопку с текстом "Drop"
            local clicked = clickButton("DropButton", "")
            if not clicked then
                clickButton("", "Drop")
            end
        end
    end
end)

-- АВТО-СБОР
task.spawn(function()
    while true do
        task.wait(collectDelay)
        if autoCollect then
            -- Пробуем QuickStack (сбор ресурсов)
            local clicked = clickButton("QuickStack", "")
            if not clicked then
                clickButton("EquipBest", "")
            end
        end
    end
end)

print("✅ Brainrot Hub загружен! Нажми на кнопку 'FIND DROP BUTTONS' для поиска кнопок дропа")
