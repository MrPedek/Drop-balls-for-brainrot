-- ====================== BRAINROT HUB (AUTO DROP 1 BALL + AUTO COLLECT) ======================
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local vim = game:GetService("VirtualInputManager")

-- ПЕРЕМЕННЫЕ
local autoDrop = false
local autoCollect = false
local dropDelay = 0.3  -- задержка между дропами (сек)
local collectDelay = 0.5

-- ФУНКЦИЯ ТАПА
local function tap(x, y)
    pcall(function()
        vim:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait(0.02)
        vim:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end)
end

-- ПОИСК КНОПКИ ПО ИМЕНИ ИЛИ ТЕКСТУ
local function findButton(buttonName, buttonText)
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return nil, 0, 0 end
    
    local function search(container)
        for _, child in ipairs(container:GetChildren()) do
            if child:IsA("TextButton") or child:IsA("ImageButton") then
                if child.Name == buttonName then
                    local pos = child.AbsolutePosition
                    local size = child.AbsoluteSize
                    if pos.X > 0 and pos.Y > 0 then
                        return child, pos.X + size.X/2, pos.Y + size.Y/2
                    end
                end
                if buttonText and child.Text and child.Text:find(buttonText) then
                    local pos = child.AbsolutePosition
                    local size = child.AbsoluteSize
                    if pos.X > 0 and pos.Y > 0 then
                        return child, pos.X + size.X/2, pos.Y + size.Y/2
                    end
                end
            end
            local found, x, y = search(child)
            if found then return found, x, y end
        end
        return nil, 0, 0
    end
    
    return search(playerGui)
end

-- НАЖАТИЕ НА КНОПКУ
local function clickButton(buttonName, buttonText)
    local btn, x, y = findButton(buttonName, buttonText)
    if btn and x > 0 and y > 0 then
        tap(x, y)
        return true
    end
    return false
end

-- ДИАГНОСТИКА: найти все кнопки дропа
local function findDropButtons()
    print("🔍 ПОИСК КНОПОК ДРОПА...")
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then print("PlayerGui не найден") return end
    
    local function search(container, path)
        for _, child in ipairs(container:GetChildren()) do
            if child:IsA("TextButton") or child:IsA("ImageButton") then
                local text = child.Text or ""
                if text:lower():find("drop") or text:lower():find("ball") or child.Name:lower():find("drop") then
                    print("🔘 Найдена: " .. child.Name .. " | Текст: " .. text .. " | Путь: " .. path .. "." .. child.Name)
                end
            end
            search(child, path .. "." .. child.Name)
        end
    end
    search(playerGui, "PlayerGui")
end

-- ====================== СОЗДАНИЕ GUI ======================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "BrainrotHub"
screenGui.ResetOnSpawn = false

-- ОСНОВНОЕ ОКНО
local mainFrame = Instance.new("Frame")
