-- ЛОГИКА КНОПОК
btnDrop.MouseButton1Click:Connect(function()
    autoDrop = not autoDrop
    if autoDrop then
        btnDrop.Text = "🟢 AUTO DROP (1 BALL): ON"
        btnDrop.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
    else
        btnDrop.Text = "🔴 AUTO DROP (1 BALL): OFF"
        btnDrop.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
